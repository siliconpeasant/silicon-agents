{
  "$schema": "https://json.schemastore.org/claude-code-plugin.json",
  "name": "silicon-crew",
  "version": "1.0.0",
  "description": "Silicon Crew — gated SoC documentation, RTL, verification, synthesis and OpenROAD physical-design roles with MCP-only EDA execution, top integration, register generation, and clock/reset design tools.",
  "author": {
    "name": "Silicon Peasant",
    "url": "https://github.com/siliconpeasant"
  },
  "keywords": [
    "soc",
    "rtl",
    "verilog",
    "verification",
    "synthesis",
    "multi-agent",
    "skill",
    "mcp",
    "clock-tree",
    "reset-tree",
    "diagram",
    "openroad",
    "physical-design",
    "siliconpeasant"
  ],
  "homepage": "https://github.com/siliconpeasant/silicon-agents",
  "mcpServers": {
    "soc-build": {
      "command": "/bin/sh",
      "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/run_mcp_python.sh", "${CLAUDE_PLUGIN_ROOT}/skills/soc-build/mcp_server.py"]
    },
    "soc-integrate": {
      "command": "/bin/sh",
      "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/run_mcp_python.sh", "${CLAUDE_PLUGIN_ROOT}/skills/soc-integrate/mcp_server.py"]
    },
    "yml2reg": {
      "command": "/bin/sh",
      "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/run_mcp_python.sh", "${CLAUDE_PLUGIN_ROOT}/skills/yml2reg/mcp_server.py"]
    },
    "excel-yml-gen": {
      "command": "/bin/sh",
      "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/run_mcp_python.sh", "${CLAUDE_PLUGIN_ROOT}/skills/excel-yml-gen/mcp_server.py"]
    },
    "crg-req-to-design": {
      "command": "/bin/sh",
      "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/run_mcp_python.sh", "${CLAUDE_PLUGIN_ROOT}/skills/crg-req-to-design/mcp_server.py"]
    },
    "cr-tree-diag-gen": {
      "command": "/bin/sh",
      "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/run_mcp_python.sh", "${CLAUDE_PLUGIN_ROOT}/skills/cr-tree-diag-gen/mcp_server.py"]
    },
    "soc-openroad": {
      "command": "/bin/sh",
      "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/run_mcp_python.sh", "${CLAUDE_PLUGIN_ROOT}/skills/soc-openroad/mcp_server.py"]
    }
  }
}
